# JWT secret – change this to a long random string in production
JWT_SECRET=community-hero-secret-key-change-me

# Server port (use 3001 to avoid conflicts with Nirvana running on 3000)
PORT=3001

# Firebase project ID (must match the service account key file below)
FIREBASE_PROJECT_ID=your-firebase-project-id

# Path to the Firebase Admin SDK service account key JSON file.
# Generate this from: Firebase Console → Project Settings → Service Accounts → Generate new private key
# Place the downloaded file at server/config/firebase-service-account.json (already in .gitignore)
# and leave this variable unset, OR set it to a custom absolute path.
FIREBASE_SERVICE_ACCOUNT_PATH=./server/config/firebase-service-account.json

# Google Gemini API Key for AI features
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
